# development = pretty logs; production recommended for long-running service
NODE_ENV=production
# Unique default port for this project (override anytime; Admin PM2 page can change it)
PORT=3847
HOST=0.0.0.0

# Optional: override data home (default ~/.gctoac when using global CLI)
# GCTOAC_HOME=/path/to/home

# SQLite — absolute file: path, or relative to prisma/ when developing in-repo
DATABASE_URL="file:../data/gateway.db"

# 32-byte key, base64-encoded (generate: openssl rand -base64 32)
ENCRYPTION_KEY=

# Optional: seed will create this admin key if set; otherwise generates a random one
# ADMIN_BOOTSTRAP_KEY=gk_live_your_admin_key_here

GROK_BIN=grok
GROK_DEFAULT_MODEL=grok-4.5
GROK_DEFAULT_CWD=.
# Comma-separated absolute paths allowed for --cwd (empty = only GROK_DEFAULT_CWD)
GROK_CWD_ALLOWLIST=
GROK_TIMEOUT_MS=600000
GROK_MAX_CONCURRENT=4
GROK_ALWAYS_APPROVE=true
# Force all API keys into safe mode (overrides per-key agent)
GROK_SAFE_MODE=false
GROK_SAFE_MAX_TURNS=4
GROK_SAFE_TIMEOUT_MS=120000
ADMIN_PANEL_ENABLED=true
# Allow Admin UI to control PM2 (start/stop/restart for grok-openai-gateway only)
PM2_ADMIN_ENABLED=true

CORS_ORIGINS=http://localhost:3847,http://127.0.0.1:3847
# --- DDoS / rate limits: initial defaults only ---
# After first boot, Admin → DDoS Center policy is authoritative (stored in DB).
# Reset to these env values via Admin → DDoS → "Reset to env defaults".
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
# Unauthenticated / IP-only cap (stricter than RATE_LIMIT_MAX)
RATE_LIMIT_IP_MAX=60
# Short burst window for chat (10s) — window also editable in Admin policy
CHAT_BURST_MAX=20
# Temporary IP block after repeated failed auth (auto-auth rule defaults)
BLOCK_FAILED_AUTH_THRESHOLD=20
BLOCK_FAILED_AUTH_WINDOW_MS=300000
BLOCK_DURATION_MS=600000
BODY_LIMIT=1mb
# Max single upload size (bytes). Larger uploads are rejected before processing.
UPLOAD_MAX_BYTES=10485760
# Below this size → encrypted in SQLite; above → encrypted file under STORAGE_DIR
DOCUMENT_DB_MAX_BYTES=1048576
# Absolute or relative path for encrypted large documents (*.enc)
STORAGE_DIR=./storage

LOG_LEVEL=info
# Reverse proxy / CDN client IP (nginx, Cloudflare, load balancer)
# TRUST_PROXY hops: 0=off (socket only), 1=nginx or CF→app (default), 2=CF→nginx→app
# Legacy: true→1, false→0. Can also be set in Admin → DDoS → Reverse proxy (runtime).
TRUST_PROXY=1
# auto | cloudflare | nginx | x-forwarded-for | socket
PROXY_IP_SOURCE=auto

# Durable chat work-queue backend (every conversation is enqueued then consumed)
# sqlite = ChatJob table + in-process worker (default, production-ready)
# redis / kafka = reserved for multi-node (not implemented yet)
QUEUE_BACKEND=sqlite
