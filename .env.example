NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# SQLite file. Path is relative to prisma/schema.prisma → project-root data/
DATABASE_URL="file:../data/gateway.db"

# 32-byte key, base64-encoded (generate: openssl rand -base64 32)
ENCRYPTION_KEY=

# Optional: seed will create this admin key if set; otherwise generates a random one
# ADMIN_BOOTSTRAP_KEY=gk_live_your_admin_key_here

GROK_BIN=grok
GROK_DEFAULT_MODEL=grok-4.5
GROK_DEFAULT_CWD=.
# Comma-separated absolute paths allowed for --cwd (empty = only GROK_DEFAULT_CWD)
GROK_CWD_ALLOWLIST=
GROK_TIMEOUT_MS=600000
GROK_MAX_CONCURRENT=4
GROK_ALWAYS_APPROVE=true
# Force all API keys into safe mode (overrides per-key agent)
GROK_SAFE_MODE=false
GROK_SAFE_MAX_TURNS=4
GROK_SAFE_TIMEOUT_MS=120000
ADMIN_PANEL_ENABLED=true

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
BODY_LIMIT=1mb
UPLOAD_MAX_BYTES=10485760
# Files larger than this are stored on disk (encrypted); smaller in DB
DOCUMENT_DB_MAX_BYTES=1048576
STORAGE_DIR=./storage

LOG_LEVEL=info
TRUST_PROXY=true
