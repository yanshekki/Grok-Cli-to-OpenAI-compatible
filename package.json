{
  "name": "grok-cli-to-openai-compatible",
  "version": "1.2.2",
  "description": "OpenAI-compatible API gateway for Grok CLI — with Admin panel, safe mode, and gctoac CLI",
  "keywords": [
    "grok",
    "xai",
    "openai",
    "openai-compatible",
    "cli",
    "gateway",
    "gctoac",
    "gcoa"
  ],
  "homepage": "https://github.com/yanshekki/Grok-Cli-to-OpenAI-compatible",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yanshekki/Grok-Cli-to-OpenAI-compatible.git"
  },
  "bugs": {
    "url": "https://github.com/yanshekki/Grok-Cli-to-OpenAI-compatible/issues"
  },
  "license": "MIT",
  "author": "yanshekki",
  "main": "dist/server.js",
  "bin": {
    "gctoac": "dist/cli/index.js",
    "gcoa": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "generated",
    "prisma",
    "public",
    "scripts",
    "README.md",
    "README-ZH.md",
    "LICENSE",
    ".env.example"
  ],
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "prisma generate && tsc -p tsconfig.json && node -e \"require('fs').chmodSync('dist/cli/index.js',0o755)\"",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "mkdir -p data && prisma migrate dev",
    "prisma:deploy": "mkdir -p data && prisma migrate deploy",
    "db:setup": "mkdir -p data && prisma migrate deploy && tsx prisma/seed.ts",
    "seed": "tsx prisma/seed.ts",
    "smoke": "bash scripts/smoke.sh",
    "prepare": "node scripts/prepare.cjs",
    "postinstall": "node scripts/postinstall.cjs",
    "prepublishOnly": "npm run build"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "6.5.0",
    "commander": "^13.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "execa": "^8.0.1",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "multer": "^1.4.5-lts.1",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.13.10",
    "@vitest/coverage-v8": "^3.0.9",
    "pino-pretty": "^13.0.0",
    "prisma": "6.5.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  },
  "engines": {
    "node": ">=20"
  }
}
