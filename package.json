{
  "name": "grok-cli-to-openai-compatible",
  "version": "1.5.0",
  "description": "OpenAI-compatible API gateway for Grok CLI — with Admin panel, safe mode, and gctoac CLI",
  "keywords": [
    "grok",
    "xai",
    "openai",
    "openai-compatible",
    "cli",
    "gateway",
    "gctoac",
    "gcoa"
  ],
  "homepage": "https://github.com/yanshekki/Grok-Cli-to-OpenAI-compatible",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yanshekki/Grok-Cli-to-OpenAI-compatible.git"
  },
  "bugs": {
    "url": "https://github.com/yanshekki/Grok-Cli-to-OpenAI-compatible/issues"
  },
  "license": "MIT",
  "author": "yanshekki",
  "main": "dist/server.js",
  "bin": {
    "gctoac": "dist/cli/index.js",
    "gcoa": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "prisma",
    "public",
    "scripts",
    "README.md",
    "README-ZH.md",
    "LICENSE",
    ".env.example"
  ],
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:admin": "vite --config admin/vite.config.ts",
    "build:admin": "vite build --config admin/vite.config.ts",
    "build": "node scripts/generate-allowed-extensions.cjs && npx prisma@6.5.0 generate && tsc -p tsconfig.json && node -e \"require('fs').chmodSync('dist/cli/index.js',0o755)\" && npm run build:admin",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:admin": "vitest run --project admin-node --project admin-dom",
    "test:admin:l1": "vitest run --project admin-node tests/admin/unit/l1",
    "test:admin:l2": "vitest run --project admin-node tests/admin/unit/l2",
    "test:admin:l3": "vitest run --project admin-dom",
    "test:admin:watch": "vitest --project admin-node --project admin-dom",
    "test:api": "vitest run --project server tests/integration/admin tests/integration/v1 tests/integration/admin.routes.test.ts tests/integration/admin.routes.full.test.ts tests/integration/v1.*.test.ts tests/integration/health.routes.test.ts",
    "test:cli": "vitest run --project server tests/unit/cli tests/unit/cli-*.test.ts tests/integration/cli.smoke.test.ts",
    "test:registry": "vitest run --project server tests/integration/admin/routes.registry.test.ts tests/integration/v1/routes.registry.test.ts tests/unit/cli/registry.test.ts && vitest run --project admin-node tests/admin/contract",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:admin": "tsc -p admin/tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\" \"admin/src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" \"tests/**/*.ts\" \"admin/src/**/*.ts\" --fix",
    "prisma:generate": "npx prisma@6.5.0 generate",
    "prisma:migrate": "mkdir -p data && npx prisma@6.5.0 migrate dev",
    "prisma:deploy": "mkdir -p data && npx prisma@6.5.0 migrate deploy",
    "db:setup": "mkdir -p data && npx prisma@6.5.0 migrate deploy && tsx prisma/seed.ts",
    "seed": "tsx prisma/seed.ts",
    "smoke": "bash scripts/smoke.sh",
    "prepare": "node scripts/prepare.cjs",
    "postinstall": "node scripts/postinstall.cjs",
    "prepublishOnly": "npm run build"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "6.5.0",
    "commander": "^13.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "execa": "5.1.1",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "multer": "^1.4.5-lts.1",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "prisma": "6.5.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.13.10",
    "@vitest/coverage-v8": "^3.0.9",
    "eslint": "^9.39.5",
    "happy-dom": "^15.11.7",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.3",
    "typescript": "5.8",
    "typescript-eslint": "^8.64.0",
    "vite": "^6.4.3",
    "vitest": "^3.0.9"
  },
  "engines": {
    "node": ">=20"
  }
}
