generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model ApiKey {
  id         String    @id @default(uuid())
  name       String
  keyPrefix  String
  keyHash    String    @unique
  role       String    @default("client")
  /// safe | agent
  mode       String    @default("safe")
  isActive   Boolean   @default(true)
  rateLimit  Int       @default(60)
  maxTurns   Int?
  timeoutMs  Int?
  /// JSON string array of IPs/CIDRs; empty/null = allow all
  ipWhitelist String?
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?

  chatRequests  ChatRequest[]
  documents     Document[]
  auditLogs     AuditLog[]
  conversations ChatConversation[]

  @@index([keyPrefix])
  @@index([isActive])
  @@index([mode])
  @@map("api_keys")
}

model IpBlacklist {
  id        String    @id @default(uuid())
  ip        String    @unique
  reason    String?
  /// manual | auto-auth | auto-rate
  source    String    @default("manual")
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  createdBy String?

  @@index([expiresAt])
  @@map("ip_blacklist")
}

model ChatRequest {
  id                 String   @id @default(uuid())
  requestId          String   @unique
  apiKeyId           String
  model              String
  stream             Boolean  @default(false)
  status             String
  durationMs         Int?
  grokSessionId      String?
  promptCiphertext   Bytes
  promptIv           Bytes
  promptTag          Bytes
  responseCiphertext Bytes?
  responseIv         Bytes?
  responseTag        Bytes?
  errorMessage       String?
  ip                 String?
  userAgent          String?
  /// resolved policy mode used for this request
  policyMode         String?
  createdAt          DateTime @default(now())

  apiKey    ApiKey                @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  documents ChatRequestDocument[]

  @@index([apiKeyId, createdAt])
  @@index([status])
  @@map("chat_requests")
}

model Document {
  id                String    @id @default(uuid())
  apiKeyId          String
  originalName      String
  mimeType          String
  sizeBytes         Int
  storageType       String
  contentCiphertext Bytes?
  contentIv         Bytes?
  contentTag        Bytes?
  storagePath       String?
  checksumSha256    String
  createdAt         DateTime  @default(now())
  deletedAt         DateTime?

  apiKey       ApiKey                @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  chatRequests ChatRequestDocument[]

  @@index([apiKeyId, createdAt])
  @@index([deletedAt])
  @@map("documents")
}

model ChatRequestDocument {
  chatRequestId String
  documentId    String

  chatRequest ChatRequest @relation(fields: [chatRequestId], references: [id], onDelete: Cascade)
  document    Document    @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@id([chatRequestId, documentId])
  @@map("chat_request_documents")
}

model AuditLog {
  id         String   @id @default(uuid())
  apiKeyId   String?
  action     String
  resource   String?
  resourceId String?
  metaJson   String?
  ip         String?
  createdAt  DateTime @default(now())

  apiKey ApiKey? @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)

  @@index([apiKeyId, createdAt])
  @@index([action, createdAt])
  @@map("audit_logs")
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("settings")
}

/// One-time admin panel login codes (CLI-generated).
model AdminOtp {
  id        String    @id @default(uuid())
  /// scrypt hash of the plaintext code
  codeHash  String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  createdIp String?

  @@index([expiresAt])
  @@map("admin_otps")
}

/// Admin SPA sessions issued after successful OTP login.
model AdminSession {
  id         String    @id @default(uuid())
  tokenHash  String    @unique
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?
  ip         String?
  userAgent  String?

  @@index([expiresAt])
  @@map("admin_sessions")
}

/// Admin playground multi-turn threads (not ChatRequest audit logs).
model ChatConversation {
  id                 String   @id @default(uuid())
  /// Custom topic/title; empty → UI falls back to preview
  title              String   @default("")
  apiKeyId           String?
  model              String?
  systemPrompt       String   @default("")
  /// JSON: { version: 1, messages: [{role,content,reasoning?,docs?}] }
  messagesCiphertext Bytes
  messagesIv         Bytes
  messagesTag        Bytes
  messageCount       Int      @default(0)
  /// First user message snippet for list (plain)
  preview            String   @default("")
  /// Context policy for next API turns: full | summary | recent
  contextMode        String   @default("full")
  contextRecentN     Int      @default(6)
  /// LLM summary (display + optional API context); not a chat bubble
  summaryText        String   @default("")
  summaryAt          DateTime?
  summarySourceCount Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  apiKey ApiKey? @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)

  @@index([updatedAt])
  @@index([apiKeyId, updatedAt])
  @@map("chat_conversations")
}

/// Durable chat work queue (Kafka-like admission + lease).
model ChatJob {
  id                   String    @id @default(uuid())
  requestId            String
  apiKeyId             String
  /// v1 | playground
  source               String    @default("v1")
  /// queued | leased | running | succeeded | failed | cancelled | dead
  status               String    @default("queued")
  /// lower = higher priority
  priority             Int       @default(100)
  attempt              Int       @default(0)
  maxAttempts          Int       @default(1)
  leaseOwner           String?
  leaseUntil           DateTime?
  notBefore            DateTime?
  queuedAt             DateTime  @default(now())
  startedAt            DateTime?
  finishedAt           DateTime?
  cancelRequested      Boolean   @default(false)
  model                String?
  stream               Boolean   @default(true)
  /// encrypted JSON payload (dto + context)
  payloadCiphertext    Bytes
  payloadIv            Bytes
  payloadTag           Bytes
  resultChatRequestId  String?
  errorCode            String?
  errorMessage         String?
  idempotencyKey       String?

  @@index([status, priority, queuedAt])
  @@index([apiKeyId, status, queuedAt])
  @@index([leaseUntil])
  @@index([requestId])
  @@unique([idempotencyKey])
  @@map("chat_jobs")
}
