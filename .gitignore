node_modules/
# Keep dist/ committed so `npm install -g github:…` works without a local build.
# Rebuild with `npm run build` before release commits.
.env
.env.local
storage/*
!storage/.gitkeep
logs/*
!logs/.gitkeep
data/*
!data/.gitkeep
*.db
*.db-journal
*.db-wal
*.db-shm
*.log
.DS_Store
coverage/
.prisma/
*.tsbuildinfo
.vitest/
*.tgz

